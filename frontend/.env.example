# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the browser.

# Backend base URL (FastAPI). Defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin token that gates GET /api/metrics. MUST match ADMIN_TOKEN in the
# backend .env, otherwise the concierge live-telemetry pill gets 403 and shows
# "Could not reach metrics". GET /api/eval is public and needs no token.
NEXT_PUBLIC_METRICS_TOKEN=your_admin_token_here
